# Mr QR — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit the .env file to source control.

# ── VirusTotal ────────────────────────────────────────────────────────────────
# Free tier available at virustotal.com
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here

# ── GMI Cloud — inference (Gemini / DeepSeek / etc.) + Playwright worker ─────
# Get your key at: console.gmicloud.ai
ROCKETRIDE_GMI_API_KEY=your-gmi-cloud-api-key-here
GMI_INFERENCE_URL=https://api.gmi-serving.com/v1
GMI_ANALYSIS_MODEL=google/gemini-3.1-pro-preview

# ── GMI Playwright worker ─────────────────────────────────────────────────────
# Local (default): http://localhost:8001
# Cloud Run (optional fallback): https://mr-qr-gmi-worker-701295024649.us-central1.run.app
GMI_WORKER_URL=http://localhost:8001

# ── Playwright tuning (optional) ──────────────────────────────────────────────
RENDER_TIMEOUT_MS=15000
