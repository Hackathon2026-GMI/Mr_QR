# ─── Mr QR — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit the .env file to source control.

# ── VirusTotal (free tier — virustotal.com) ───────────────────────────────────
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here

# ── GMI Cloud — used by the Rocketride pipeline's LLM node (mr_qr_security.pipe)
# Get your key at: console.gmicloud.ai
ROCKETRIDE_GMI_API_KEY=your-gmi-cloud-api-key-here

# ── Deep scan worker — gmi_worker.py deployed on Google Cloud Run (or any host)
# After running: gcloud run deploy mr-qr-gmi-worker ...
# paste the Cloud Run URL here
GMI_WORKER_URL=https://mr-qr-gmi-worker-xxxx-uc.a.run.app

# ── Google AI Studio — Gemini 1.5 Flash ──────────────────────────────────────
# Get your key at: aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-ai-studio-api-key-here

# ── Worker tuning (optional) ──────────────────────────────────────────────────
RENDER_TIMEOUT_MS=15000

# ── Rocketride (only needed if using the .pipe file via the Rocketride SDK/CLI)
# ROCKETRIDE_URI=https://cloud.rocketride.ai
# ROCKETRIDE_APIKEY=your-rocketride-api-key-here
