        "formDataValid": true
      }
    },
    {
      "id": "llm_gmi_cloud_1",
      "provider": "llm_gmi_cloud",
      "config": {
        "profile": "google/gemini-3.1-flash-preview",
        "google/gemini-3.1-flash-preview": {
          "apikey": "${ROCKETRIDE_GMI_API_KEY}"
        },
        "parameters": {}
      },
      "control": [
        { "classType": "llm", "from": "agent_rocketride_1" }
      ],
      "ui": {
        "position": { "x": 570, "y": 390 },
        "measured": { "width": 150, "height": 66 },
