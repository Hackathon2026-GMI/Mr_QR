        "formDataValid": true
      }
    },
    {
      "id": "tool_http_request_1",
      "provider": "tool_http_request",
      "config": {
        "type": "tool_http_request",
        "allowGET": true,
        "allowPOST": true,
        "allowPUT": false,
        "allowPATCH": false,
        "allowDELETE": false,
        "allowHEAD": false,
        "allowOPTIONS": false,
        "rateLimitPerSecond": 2,
        "rateLimitPerMinute": 20,
        "maxConcurrentRequests": 2,
        "urlWhitelist": [
          { "whitelistPattern": "^https://www\\.virustotal\\.com/api/v3/.*" }
        ]
      },
      "control": [
        { "classType": "tool", "from": "agent_rocketride_1" }
      ],
      "ui": {
        "position": { "x": 390, "y": 530 },
        "measured": { "width": 150, "height": 40 },
        "nodeType": "default",
